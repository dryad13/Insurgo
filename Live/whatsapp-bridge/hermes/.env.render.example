# Hermes core provider
OPENROUTER_API_KEY=replace_with_real_openrouter_key

# Gateway security
GATEWAY_ALLOW_ALL_USERS=true

# WhatsApp channel
WHATSAPP_ENABLED=true
# Leave blank for open public mode when GATEWAY_ALLOW_ALL_USERS=true.
# If set, this should include admin/operator numbers only.
WHATSAPP_ALLOWED_USERS=

# Admin override: E.164 with plus. This number gets full admin toolset.
HERMES_ADMIN_E164=+92333728901
# Optional multiple admins (comma-separated)
# HERMES_ADMIN_E164_LIST=+92333728901,+16862046914

# Persistent Hermes paths (mount disk at /var/lib/hermes)
HERMES_HOME=/var/lib/hermes
XDG_CONFIG_HOME=/var/lib/hermes/config

# Optional runtime knobs
TERMINAL_TIMEOUT=90
TERMINAL_LIFETIME_SECONDS=300
WEB_TOOLS_DEBUG=false

# Optional startup controls for platforms without native one-off jobs:
# - Set HERMES_PAUSE_START=true to keep container alive for shell access.
# - Set HERMES_ONE_OFF_COMMAND="hermes whatsapp" for one deploy cycle to pair.
# HERMES_PAUSE_START=false
# HERMES_ONE_OFF_COMMAND=
