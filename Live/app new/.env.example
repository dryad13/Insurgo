# Copy to .env.local (for `netlify dev`) or set these in Netlify site settings
# → Site configuration → Environment variables.
#
# NEVER commit a real key. .env.local is gitignored.

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the default model. Any OpenRouter-supported slug works:
#   anthropic/claude-3.5-sonnet   (default)
#   openai/gpt-4o-mini
#   meta-llama/llama-3.1-70b-instruct
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# WhatsApp bridge URL used by Netlify functions:
#   local: http://localhost:8787
#   prod:  https://your-whatsapp-bridge.example.com
# WA_BRIDGE_URL=http://localhost:8787

# For Render static deployments (client-side WhatsApp admin calls):
# VITE_WA_BRIDGE_URL=https://your-whatsapp-bridge.onrender.com
